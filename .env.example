# shared ground — environment variables
# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored — never commit real keys to the repo.
#
# Find these values in: Supabase → your project → Settings → API
# Use the LEGACY anon key (Settings → API Keys → Legacy anon, service_role API keys → anon)

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
